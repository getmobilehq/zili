{
  "name": "zili",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@8.15.1",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "pnpm --filter @zili/web dev",
    "build": "pnpm --filter @zili/web build",
    "lint": "pnpm -r --if-present lint && prettier --check \"{apps,packages}/**/*.{ts,tsx,css}\"",
    "format": "prettier --write \"{apps,packages}/**/*.{ts,tsx,css}\"",
    "typecheck": "pnpm -r --if-present typecheck",
    "test": "pnpm -r --if-present test",
    "test:e2e": "playwright test",
    "test:e2e:update": "playwright test --update-snapshots"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.1",
    "prettier": "^3.3.3"
  }
}
